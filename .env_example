# Database
POSTGRES_USER=        # имя пользователя postgres
POSTGRES_PASSWORD=    # пароль postgres
POSTGRES_DB=          # название базы данных
DATABASE_URL=         # полная строка подключения

# Auth
JWT_SECRET=           # секрет для подписи JWT, минимум 32 символа
TOKEN_TTL=24h         # время жизни JWT (например, 1h, 30m, 24h)

# Server
SERVER_PORT=50051         # порт сервера
LOG_LEVEL=            # development или production